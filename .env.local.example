# 🚀 CONFIGURACIÓN PARA DESARROLLO LOCAL (SUPABASE)
# Copia estas variables a tu .env.local cuando quieras trabajar localmente.
# Primero debes ejecutar: npm run supabase:start

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-here

# Nota: Las llaves reales las obtendrás ejecutando 'npm run supabase:status' 
# una vez que el entorno local esté iniciado.
